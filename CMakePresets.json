{
  "version": 3,
  "configurePresets": [
    {
      "name": "Default",
      "binaryDir": "${sourceDir}/build",
      "installDir": "${sourceDir}/dist",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "CPU",
      "inherits": ["Default"],
      "cacheVariables": {
        "GGML_VULKAN": "OFF",
        "GGML_CUDA": "OFF",
        "GGML_HIP": "OFF"
      }
    },
    {
      "name": "CUDA",
      "inherits": ["Default"],
      "cacheVariables": {
        "GGML_CUDA": "ON",
        "GGML_VULKAN": "OFF",
        "GGML_HIP": "OFF"
      }
    },
    {
      "name": "CUDA 12",
      "inherits": ["CUDA"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "50;52;60;61;70;75;80;86;89;90;90a",
        "CMAKE_CUDA_FLAGS": "-Wno-deprecated-gpu-targets -t 2",
        "KOCORT_BACKEND_DIR": "cuda_v12"
      }
    },
    {
      "name": "CUDA 13",
      "inherits": ["CUDA"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "75-virtual;80-virtual;86-virtual;87-virtual;89-virtual;90-virtual;90a-virtual;100-virtual;120-virtual",
        "CMAKE_CUDA_FLAGS": "-t 4",
        "KOCORT_BACKEND_DIR": "cuda_v13"
      }
    },
    {
      "name": "ROCm",
      "inherits": ["Default"],
      "cacheVariables": {
        "GGML_HIP": "ON",
        "GGML_CUDA": "OFF",
        "GGML_VULKAN": "OFF",
        "CMAKE_HIP_PLATFORM": "amd"
      }
    },
    {
      "name": "ROCm 6",
      "inherits": ["ROCm"],
      "cacheVariables": {
        "CMAKE_HIP_FLAGS": "-parallel-jobs=4",
        "AMDGPU_TARGETS": "gfx940;gfx941;gfx942;gfx1010;gfx1012;gfx1030;gfx1100;gfx1101;gfx1102;gfx1151;gfx1200;gfx1201;gfx908:xnack-;gfx90a:xnack+;gfx90a:xnack-",
        "KOCORT_BACKEND_DIR": "rocm"
      }
    },
    {
      "name": "Vulkan",
      "inherits": ["Default"],
      "cacheVariables": {
        "GGML_VULKAN": "ON",
        "GGML_CUDA": "OFF",
        "GGML_HIP": "OFF",
        "KOCORT_BACKEND_DIR": "vulkan"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Default",
      "configurePreset": "Default",
      "configuration": "Release"
    },
    {
      "name": "CPU",
      "configurePreset": "CPU"
    },
    {
      "name": "CUDA",
      "configurePreset": "CUDA",
      "targets": ["ggml-base", "ggml", "ggml-cuda"]
    },
    {
      "name": "CUDA 12",
      "inherits": ["CUDA"],
      "configurePreset": "CUDA 12"
    },
    {
      "name": "CUDA 13",
      "inherits": ["CUDA"],
      "configurePreset": "CUDA 13"
    },
    {
      "name": "ROCm",
      "configurePreset": "ROCm",
      "targets": ["ggml-base", "ggml", "ggml-hip"]
    },
    {
      "name": "ROCm 6",
      "inherits": ["ROCm"],
      "configurePreset": "ROCm 6"
    },
    {
      "name": "Vulkan",
      "configurePreset": "Vulkan",
      "targets": ["ggml-base", "ggml", "ggml-vulkan"]
    }
  ]
}
